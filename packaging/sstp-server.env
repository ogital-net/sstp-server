# /etc/sstp-server/sstp-server.env
#
# Environment file for the sstp-server systemd unit. Loaded by
# `EnvironmentFile=-/etc/sstp-server/sstp-server.env`.
#
# This file should be mode 0640, owned root:sstp-server. The
# postinst script enforces those permissions on package install.

# REQUIRED: shared secret for the RADIUS authentication server(s).
# Never pass this on the command line — it leaks into `ps` output
# and shell history.
SSTP_RADIUS_SECRET=changeme

# Optional: separate secret for accounting servers. Defaults to
# SSTP_RADIUS_SECRET when unset.
#SSTP_RADIUS_ACCT_SECRET=changeme

# Optional: passphrase for an encrypted TLS private key.
#SSTP_TLS_KEY_PASSWORD=

# Daemon command-line options. Tweak to match your deployment.
# Required flags: --cert, --key, --radius, --local-ip.
# NOTE: systemd's EnvironmentFile parser does not honour shell-style
# line continuations; keep OPTS on a single line.
#
# Default logging: structured JSON to /var/log/sstp-server/sstp-server.log
# (rotated by /etc/logrotate.d/sstp-server). Drop --log-file to send
# logs to stderr / journald instead.
OPTS=--listen [::]:443 --cert /etc/sstp-server/server.crt --key /etc/sstp-server/server.key --radius 127.0.0.1:1812 --local-ip 10.255.255.1 --control-socket /run/sstp-server/sstp-server.sock --log-file /var/log/sstp-server/sstp-server.log -v
